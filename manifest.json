{
  "manifest_version": 3,
  "name": "Dubplitube Downloader",
  "version": "1.0.13",
  "description": "Premium YouTube & Shorts Downloader in 4K, MP3, and HD quality with a gorgeous neon interface.",
  "homepage_url": "https://github.com/agasdee/Youtube-Downloader-Extension",
  "icons": {
    "128": "logo/icon128.png"
  },
  "permissions": [
    "downloads",
    "downloads.open",
    "scripting",
    "storage",
    "unlimitedStorage"
  ],
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://youtu.be/*"
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*", "https://youtu.be/*"],
      "js": ["src/content.js"],
      "css": ["src/styles.css"]
    }
  ],
  "action": {
    "default_popup": "src/popup.html",
    "default_icon": {
      "128": "logo/icon128.png"
    }
  }
}
